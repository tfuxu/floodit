<?xml version='1.0' encoding='utf-8'?>
<component type="desktop-application">
  <id>@APP_ID@</id>
  <name>Flood It</name>
  <summary>Flood the board</summary>
  <developer id="io.github.tfuxu">
    <name translate="no">tfuxu</name>
  </developer>
  <launchable type="desktop-id">@APP_ID@.desktop</launchable>
  <translation type="gettext">floodit</translation>
  <metadata_license>CC-BY-SA-4.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
  <update_contact>tfuxu@tutanota.com</update_contact>
  <content_rating type="oars-1.1"/>

  <description>
    <p>
      Flood It is a game with the simple premise of flooding the entire board with one color in the least amount of moves possible.

      Challenge yourself with this simple, yet addictive strategy game, where you need to flood-it as efficiently as you can!
    </p>
  </description>

  <screenshots>
    <screenshot type="default">
      <image type="source">https://raw.githubusercontent.com/tfuxu/floodit/master/data/screenshots/screenshot-3.png</image>
    </screenshot>
    <screenshot>
      <image type="source">https://raw.githubusercontent.com/tfuxu/floodit/master/data/screenshots/screenshot-2.png</image>
    </screenshot>
    <screenshot>
      <image type="source">https://raw.githubusercontent.com/tfuxu/floodit/master/data/screenshots/screenshot-4.png</image>
    </screenshot>
  </screenshots>

  <branding>
    <color type="primary" scheme_preference="light">#62a0ea</color>
    <color type="primary" scheme_preference="dark">#1a5fb4</color>
  </branding>

  <url type="homepage">@PROJECT_URL@</url>
  <url type="vcs-browser">@VCS_BROWSER_URL@</url>
  <url type="bugtracker">@BUGTRACKER_URL@</url>
  <url type="help">@HELP_URL@</url>
  <!--<url type="translate">@TRANSLATE_URL@</url>-->

  <requires>
    <internet>offline-only</internet>
    <display_length compare="ge">360</display_length>
  </requires>

  <supports>
    <control>keyboard</control>
    <control>pointing</control>
    <control>touch</control>
  </supports>

  <custom>
    <value key="Purism::form_factor">mobile</value>
  </custom>

  <releases>
    <release version="2.0.0" date="2026-03-27">
      <description translate="no">
        <p>
          After almost 2 years since the last release, there's finally another!
          It brings the ability to replay the board, shortcuts for color buttons that allow you to easily play the game using only the keyboard and full translation support that makes the game easier for international players to understand.
          There are also many under-the-hood improvements that will make developing future features much easier (and in some cases, possible).
        </p>

        <p>General changes:</p>
        <ul>
          <li>Added ability to replay the board</li>
          <li>Added shortcuts for color buttons</li>
          <li>Made almost all visible text translatable</li>
          <li>Added more information to the game result page (Now it says which difficulty level you won/lost)</li>
          <li>Added Turkish (tr) translation</li>
          <li>Added Brazilian Portuguese (pt_BR) translation</li>
          <li>Added Dutch (nl) translation</li>
          <li>Added French (fr) translation</li>
        </ul>

        <p>Technical changes:</p>
        <ul>
          <li>Changed UI library from gotk4 to puregotk (dynamic bindings, 99% faster build times, custom widgets, etc.)</li>
          <li>Added custom seed support in backend</li>
          <li>Ported shortcuts window to Adw.ShortcutsDialog (thanks in part to UrtsiSantsi)</li>
          <li>Replaced Gtk.DrawingArea with a custom widget (uses Gtk.Snapshot)</li>
          <li>Updated Gnome runtime to 50</li>
          <li>Fixed Flatpak builds in Gnome Builder</li>
        </ul>
      </description>
    </release>
    <release version="1.1.0" date="2024-10-06">
      <description translate="no">
        <ul>
          <li>Trigger game lost screen when the number of steps left is zero</li>
          <li>Fixed line artifacts showing on some parts of the board</li>
          <li>Rounded the corners of the board</li>
        </ul>
      </description>
    </release>
    <release version="1.0.0" date="2024-09-12">
      <description translate="no">
        <p>
          This is the first release of Flood It!
        </p>
      </description>
    </release>
  </releases>
</component>
